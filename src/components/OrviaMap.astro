---
// The map of Orvia. Every rust-outlined province is an anchor link to a section.
// Pure CSS + anchor scrolling, no client-side JavaScript.
//
// Province names are drawn into the SVG itself. If you rename a section in
// src/data/profile.js, update the matching <text> label in here too.
interface Props {
  inscription: string;
}
const { inscription } = Astro.props;
---

